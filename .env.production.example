# Copy to .env.production on the VPS and replace every placeholder before deploying.
# Never commit the real .env.production file.

APP_ENV=prod

# Public URLs and CORS. Preserve the current ports unless you intentionally put
# all traffic behind a reverse proxy.
PUBLIC_HOST=18.142.190.113
LOGIN_URL=http://18.142.190.113:5173
BACKEND_API_BASE_URL=http://18.142.190.113:8001
BACKEND_ORIGIN=http://backend:8000
ASSISTANT_ORIGIN=http://18.142.190.113:8500
CORS_ALLOWED_ORIGINS=http://18.142.190.113:5173,http://18.142.190.113:8001,http://18.142.190.113:8500
TRUSTED_HOSTS=18.142.190.113,localhost,127.0.0.1

# Database.
POSTGRES_USER=postgres
POSTGRES_PASSWORD=replace-with-a-long-random-password
DATABASE_URL=postgresql://postgres:replace-with-a-long-random-password@db:5432/fastapi_db
ASSISTANT_DB_URL=postgresql://postgres:replace-with-a-long-random-password@db:5432/ai_assistant

# Redis / Celery.
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0
CELERY_LOGLEVEL=info
CELERY_WORKER_POOL=solo
CELERY_WORKER_CONCURRENCY=1

# Backend security and bootstrap.
SECRET_KEY=replace-with-openssl-rand-hex-32
JWT_ALGORITHM=HS256
JWT_PUBLIC_KEY=
DEFAULT_ADMIN_EMAIL=admin@example.com
DEFAULT_ADMIN_PASSWORD=replace-with-a-strong-admin-password
API_DOCS_ENABLED=false
RATE_LIMIT_ENABLED=true
RATE_LIMIT_FAIL_OPEN=false
TEST_MODE=false
TESTING=false
FACE_SCAN_BYPASS_ALL=false
PRIVILEGED_FACE_VERIFICATION_ENABLED=false
UVICORN_WORKERS=2

# Email. Keep disabled until production sender credentials are configured.
EMAIL_DELIVERY_MODE=disabled
EMAIL_TRANSPORT=disabled
EMAIL_SENDER_EMAIL=notifications@example.com
EMAIL_SENDER_NAME=Aura Notifications
EMAIL_REPLY_TO=notifications@example.com
MAILJET_API_KEY=
MAILJET_API_SECRET=
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_USE_TLS=false
SMTP_USE_STARTTLS=true

# Google login.
GOOGLE_LOGIN_ENABLED=false
GOOGLE_WEB_CLIENT_ID=
GOOGLE_ANDROID_CLIENT_ID=

# Assistant AI provider. Production defaults to local llama.cpp via
# docker-compose.prod.yml. Put the GGUF at ./jose.gguf on the VPS.
AI_PROVIDER=openai
AI_API_KEY=sk-noop
AI_API_BASE=http://local-llm:8091/v1
AI_MODEL=jose-ai
AI_MAX_TOKENS=4096
LOCAL_AI_MODEL=jose-ai
LOCAL_AI_MODEL_FILE=jose.gguf
LOCAL_AI_MODEL_PATH=./jose.gguf
LOCAL_AI_CONTEXT_TOKENS=8192
LOCAL_AI_API_KEY=sk-noop
LOCAL_FAST_MODE=1

# Frontend runtime config.
VITE_API_BASE_URL=/__backend__/
VITE_API_TIMEOUT_MS=15000
VITE_ASSISTANT_BASE_URL=http://18.142.190.113:8500
AURA_API_BASE_URL=/__backend__/
AURA_API_TIMEOUT_MS=15000
AURA_PORT=80
