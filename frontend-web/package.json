{
  "name": "aura-frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "eslint . --max-warnings=0",
    "format:check": "prettier --check \"*.{js,json,md}\" \"scripts/**/*.mjs\" \"e2e/**/*.{js,ts}\" \"tests/**/*.js\"",
    "typecheck": "vue-tsc --noEmit -p tsconfig.json",
    "validate:env": "node ./scripts/validate-env.mjs",
    "test:unit": "vitest run --coverage",
    "test:unit:watch": "vitest",
    "check:dist": "node ./scripts/check-dist.mjs",
    "check:secrets": "node ./scripts/scan-secrets.mjs",
    "cap:config": "node ./scripts/write-capacitor-config.mjs",
    "runtime:config:dist": "node ./scripts/write-runtime-config.mjs dist/runtime-config.js",
    "cap:sync": "npm run cap:config && capacitor sync",
    "android:sync": "npm run build && npm run runtime:config:dist && npm run cap:config && capacitor sync android",
    "android:open": "npm run cap:config && capacitor open android",
    "android:build:debug": "npm run android:sync && cd aura-apk\\android && gradlew.bat assembleDebug",
    "android:build:release": "npm run android:sync && cd aura-apk\\android && gradlew.bat assembleRelease",
    "test:e2e": "playwright test",
    "test:e2e:preview": "playwright test e2e/preview-smoke.spec.ts",
    "test:e2e:critical": "playwright test e2e/frontend-backend.spec.js e2e/rbac.spec.ts e2e/preview-smoke.spec.ts",
    "test:e2e:uiux": "node ./scripts/run-playwright-suite.mjs --mock-auth e2e/workflows",
    "test:e2e:uiux:backend": "node ./scripts/run-playwright-suite.mjs --require-backend e2e/workflows",
    "playwright:install": "playwright install chromium",
    "playwright:install:ci": "playwright install --with-deps chromium"
  },
  "dependencies": {
    "@capacitor/android": "^8.3.0",
    "@capacitor/app": "^8.1.0",
    "@capacitor/camera": "^8.0.2",
    "@capacitor/cli": "^8.3.0",
    "@capacitor/core": "^8.3.0",
    "@capacitor/filesystem": "^8.1.2",
    "@capacitor/geolocation": "^8.1.0",
    "@capacitor/haptics": "^8.0.1",
    "@capacitor/keyboard": "^8.0.2",
    "@capacitor/local-notifications": "^8.0.2",
    "@capacitor/network": "^8.0.1",
    "@capacitor/share": "^8.0.1",
    "@capacitor/splash-screen": "^8.0.1",
    "@capacitor/status-bar": "^8.0.2",
    "@lottiefiles/dotlottie-vue": "^0.11.10",
    "@mediapipe/tasks-vision": "^0.10.32",
    "chart.js": "^4.5.1",
    "chartjs-plugin-datalabels": "^2.2.0",
    "dompurify": "^3.4.1",
    "highlight.js": "^11.11.1",
    "jspdf": "^4.2.1",
    "katex": "^0.16.45",
    "leaflet": "^1.9.4",
    "lucide-vue-next": "^0.577.0",
    "marked": "^18.0.2",
    "marked-highlight": "^2.2.4",
    "marked-katex-extension": "^5.1.8",
    "pinia": "^3.0.4",
    "vue": "^3.5.25",
    "vue-chartjs": "^5.3.3",
    "vue-router": "^4.6.4"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.59.1",
    "@tailwindcss/vite": "^4.2.1",
    "@vitejs/plugin-vue": "^6.0.2",
    "@vitest/coverage-v8": "^4.1.5",
    "@vue/compiler-sfc": "^3.5.33",
    "@vue/test-utils": "^2.4.10",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-unused-imports": "^4.4.1",
    "eslint-plugin-vue": "^10.9.0",
    "globals": "^17.5.0",
    "jsdom": "^29.1.1",
    "prettier": "^3.8.3",
    "tailwindcss": "^4.2.1",
    "typescript": "^6.0.3",
    "vite": "^7.3.1",
    "vitest": "^4.1.5",
    "vue-eslint-parser": "^10.4.0",
    "vue-tsc": "^3.2.7"
  }
}
