{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "ignoreDeprecations": "6.0",
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"]
    },
    "allowJs": true,
    "checkJs": false,
    "noEmit": true,
    "skipLibCheck": true,
    "strict": true
  },
  "include": [
    "src/**/*.js",
    "src/**/*.vue",
    "e2e/**/*.js",
    "tests/**/*.js",
    "scripts/**/*.mjs",
    "playwright.config.js",
    "vite.config.js",
    "vitest.config.js"
  ],
  "exclude": [
    "coverage",
    "dist",
    "node_modules",
    "playwright-report",
    "test-results"
  ]
}
