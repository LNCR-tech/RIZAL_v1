# Local backend development settings.
# Docker Compose service environment variables override these values inside containers.

DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5433/fastapi_db
DATABASE_ADMIN_URL=postgresql://postgres:postgres@127.0.0.1:5433/postgres
SECRET_KEY=dev-local-secret-key-change-before-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
ADMIN_EMAIL=admin@university.edu
ADMIN_PASSWORD=AdminPass123!

DB_POOL_SIZE=10
DB_MAX_OVERFLOW=10
DB_POOL_TIMEOUT_SECONDS=15
DB_POOL_RECYCLE_SECONDS=1800

CELERY_BROKER_URL=redis://127.0.0.1:6379/0
CELERY_RESULT_BACKEND=redis://127.0.0.1:6379/0
CELERY_TASK_TIME_LIMIT_SECONDS=10800

AUTH_ENABLE_MFA=false
FACE_SCAN_BYPASS_EMAILS=
FACE_MATCH_THRESHOLD=0.5
LIVENESS_MIN_SCORE=0.85
ALLOW_LIVENESS_BYPASS_WHEN_MODEL_MISSING=false
ANTI_SPOOF_SCALE=2.7
ANTI_SPOOF_MODEL_PATH=models/MiniFASNetV2.onnx
GEO_MAX_ALLOWED_ACCURACY_M=30
GEO_MAX_TRAVEL_SPEED_MPS=60

EVENT_STATUS_SYNC_ENABLED=true
EVENT_STATUS_SYNC_INTERVAL_SECONDS=60
PUBLIC_ATTENDANCE_ENABLED=true
PUBLIC_ATTENDANCE_MAX_FACES_PER_FRAME=10
PUBLIC_ATTENDANCE_SCAN_COOLDOWN_SECONDS=8
PUBLIC_ATTENDANCE_EVENT_LOOKAHEAD_HOURS=12
TENANT_DATABASE_PREFIX=school

IMPORT_MAX_FILE_SIZE_MB=50
IMPORT_CHUNK_SIZE=5000
IMPORT_STORAGE_DIR=storage/imports
IMPORT_RATE_LIMIT_COUNT=3
IMPORT_RATE_LIMIT_WINDOW_SECONDS=300

EMAIL_TRANSPORT=gmail_api
EMAIL_REQUIRED_ON_STARTUP=false
EMAIL_VERIFY_CONNECTION_ON_STARTUP=false
EMAIL_TIMEOUT_SECONDS=20
