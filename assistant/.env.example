# assistant/.env.example
# Copy this file to .env and fill in all values.
#
# Variable types:
#
#   [BEHAVIOR] Controls how this service behaves. Only this service reads it.
#              Independent — nothing else depends on this value.
#
#
#   [IDENTITY] Credentials or secrets that define who this service is.
#              Independent — you choose them, but other services may need to
#              copy them into their own [NEIGHBOR] variables.
#
#
#   [ENDPOINT] This service's own address or port that other services connect to.
#              You choose the value, but other services must match it.
#
#
#   [NEIGHBOR] URL or address of another service this service talks to.
#              Dependent — must match the target service's [ENDPOINT] or [IDENTITY].

# =============================================================================
# QUICK SETUP
# =============================================================================
#
# Docker (docker compose --profile dev up --build):
#
#   Required:
#     AI_API_KEY=<your-ai-api-key>
#     SECRET_KEY=<same SECRET_KEY as backend/.env>
#     ASSISTANT_DB_URL=postgresql://postgres:<password>@postgres:5432/ai_assistant
#     BACKEND_API_BASE_URL=http://backend:8000
#
#   AI backend (centralized Jose gateway):
#     AI_API_BASE=https://<jose-gateway-host>:<port>/v1
#     AI_MODEL=jose
#     AI_MAX_TOKENS=8192
#
# Manual (uvicorn main:app --port 8500 --reload):
#
#   Required:
#     AI_API_KEY=<your-ai-api-key>
#     SECRET_KEY=<same SECRET_KEY as backend/.env>
#     ASSISTANT_DB_URL=postgresql://postgres:<password>@127.0.0.1:5432/ai_assistant
#     BACKEND_API_BASE_URL=http://127.0.0.1:8000
#
#   AI backend (centralized Jose gateway):
#     AI_API_BASE=https://<jose-gateway-host>:<port>/v1
#     AI_MODEL=jose
#     AI_MAX_TOKENS=8192
#
# =============================================================================


# --- AI Provider: centralized Jose ---
# Aura consumes the centralized Jose model through its gateway, which is an
# OpenAI-compatible API. The gateway is a SEPARATE project (the sibling folder
# `centralized-jose/`); see docs/jose/aura-uses-centralized-jose.md.
# (Any other OpenAI-compatible provider also works here, but the default wiring
# is centralized Jose.)

# [BEHAVIOR] Provider family. The Jose gateway is OpenAI-compatible.
AI_PROVIDER=openai

# [NEIGHBOR] The Jose gateway base URL + /v1 (NOT llama-server directly).
#            Must match the gateway's public URL/port.
AI_API_BASE=https://<jose-gateway-host>:<port>/v1

# [IDENTITY] Aura's project API key, issued by the Jose gateway operator.
AI_API_KEY=sk-jose-aura-<your-key>

# [BEHAVIOR] Model name as configured on the gateway / llama-server.
AI_MODEL=jose

# [BEHAVIOR] Maximum tokens per response.
AI_MAX_TOKENS=8192

# --- Database ---

# [NEIGHBOR] Must match POSTGRES_USER, POSTGRES_PASSWORD, and DB_PORT in database/.env.
ASSISTANT_DB_URL=postgresql://<user>:<password>@<host>:5432/ai_assistant

# [NEIGHBOR] The backend's main database. Used by MCP tools to query school data.
#            Must match DATABASE_URL in backend/.env.
DATABASE_URL=postgresql://<user>:<password>@<host>:5432/fastapi_db

# --- Backend Integration ---

# [NEIGHBOR] Must match BACKEND_API_BASE_URL in backend/.env.
BACKEND_API_BASE_URL=http://localhost:8000

# --- Auth ---

# [IDENTITY] Must be identical to SECRET_KEY in backend/.env.
#            Both services use it to verify JWTs issued by the backend.
SECRET_KEY=<same SECRET_KEY as backend>

# [BEHAVIOR] JWT algorithm. Must match backend.
JWT_ALGORITHM=HS256

# --- CORS ---

# [ENDPOINT] This assistant's own public URL.
ASSISTANT_ORIGIN=http://localhost:8500

# [NEIGHBOR] Must match the frontend's actual URL.
CORS_ALLOWED_ORIGINS=http://localhost:5173

# --- Migrations ---

# Tables are created automatically on startup via SQLAlchemy create_all.
# No configuration needed.
