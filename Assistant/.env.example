# Copy to `Assistant/.env` for local development.
# Do not commit real secrets (API keys/JWT secrets/passwords).

# Tenant DB (website backend data)
TENANT_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/fastapi_db

# Assistant DB (assistant conversation storage)
ASSISTANT_DB_URL=postgresql://postgres:postgres@localhost:5432/ai_assistant
ASSISTANT_DB_SCHEMA=public

# JWT verification (must match the issuer/signer your client uses)
JWT_SECRET=replace_me
JWT_ALGORITHM=HS256
# JWT_PUBLIC_KEY=-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----

# LLM Provider Configuration (priority: LLM_ > OPENAI_)
LLM_MODEL=replace_me
LLM_API_KEY=replace_me
LLM_API_BASE=https://api.groq.com/openai/v1

# Optional OpenAI-compatible fallback
OPENAI_MODEL=gpt-4o
OPENAI_API_KEY=replace_me

# Optional MCP service endpoints (if you run them)
# MCP_SCHEMA_URL=http://127.0.0.1:9001/schema
# MCP_QUERY_URL=http://127.0.0.1:9002/query
# MCP_SCHOOL_ADMIN_URL=http://127.0.0.1:9003/action
# MCP_STUDENT_IMPORT_URL=http://127.0.0.1:9004/action

