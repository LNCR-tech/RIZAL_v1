# [NEIGHBOR] Backend API endpoint
DOCUSAURUS_BACKEND_URL=https://api.aura.school

# [BEHAVIOR] Enable authentication
DOCUSAURUS_AUTH_ENABLED=true

# [BEHAVIOR] Default role for unauthenticated users
DOCUSAURUS_DEFAULT_ROLE=student

# [BEHAVIOR] Authorized emails for production technical-doc access
DOCUSAURUS_AUTHORIZED_EMAILS=admin@aura.school,dev@aura.school,it@aura.school

# [BEHAVIOR] Site URL
DOCUSAURUS_SITE_URL=https://docs.aura.school
