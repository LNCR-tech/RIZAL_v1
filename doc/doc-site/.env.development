# [NEIGHBOR] Backend API endpoint (local)
DOCUSAURUS_BACKEND_URL=http://localhost:8001

# [BEHAVIOR] Disable auth for local dev
DOCUSAURUS_AUTH_ENABLED=false

# [BEHAVIOR] Default role for testing
DOCUSAURUS_DEFAULT_ROLE=admin

# [BEHAVIOR] Authorized emails for testing technical-doc access
DOCUSAURUS_AUTHORIZED_EMAILS=admin@aura.school,dev@aura.school,it@aura.school

# [BEHAVIOR] Site URL
DOCUSAURUS_SITE_URL=http://localhost:3000
