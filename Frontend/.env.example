# Frontend example environment variables
#
# This app supports both:
# - A built/static web build served by nginx (Compose dev/prod)
# - A Vite dev server workflow (optional; not used by docker-compose.yml)
#
# Nginx/runtime-config.js (used by docker-compose.yml / docker-compose.prod.yml)
AURA_API_BASE_URL=/__backend__
AURA_API_TIMEOUT_MS=15000
# Assistant (proxied by nginx in docker)
AURA_ASSISTANT_BASE_URL=/__assistant__
# Nginx uses this to proxy /__backend__/ to the backend service.
BACKEND_ORIGIN=http://backend:8000
# Nginx uses this to proxy /__assistant__/ to the assistant service.
ASSISTANT_ORIGIN=http://assistant:8500

# Vite (optional local dev)
VITE_USE_MOCK_API=false
VITE_API_BASE_URL=/__backend__
VITE_API_TIMEOUT_MS=15000
# Optional: if running the assistant separately during Vite dev
VITE_ASSISTANT_BASE_URL=/__assistant__
# For native builds (Capacitor) or proxying to a remote backend during dev.
VITE_NATIVE_API_BASE_URL=https://backend-api-production-32e5.up.railway.app/
VITE_BACKEND_PROXY_TARGET=https://backend-api-production-32e5.up.railway.app/
EMAIL_TRANSPORT=gmail_api
